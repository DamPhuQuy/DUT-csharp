<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProductManagement.Forms"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="420"
        x:Class="ProductManagement.Forms.MainWindow"
        x:CompileBindings="False"
        Title="Form1"
        Width="800" Height="420"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12" ColumnDefinitions="*,*">

        <!-- ===== LEFT PANEL ===== -->
        <StackPanel Grid.Column="0" Margin="0,0,12,0" Spacing="10">

            <!-- Đếm số SP -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Name="BtnCount" Content="Đếm số SP" Padding="10,5"/>
                <TextBlock Name="TxtCountResult" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Nhập Mã SP -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Nhập Mã SP" VerticalAlignment="Center" Width="90"/>
                <TextBox Name="TxtSearchId" Width="130"/>
            </StackPanel>

            <!-- View detail buttons -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Name="BtnViewDetail" Content="Xem chi tiết SP" Padding="8,5"/>
                <Button Name="BtnViewDetailC2" Content="Xem chi tiết SP C2" Padding="8,5"/>
            </StackPanel>

            <!-- Detail fields -->
            <Grid RowDefinitions="Auto,Auto,Auto"
                  ColumnDefinitions="50,150"
                  Margin="0,8,0,0">

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Mã:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                <TextBox   Grid.Row="0" Grid.Column="1"
                           Name="TxtId" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Tên:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                <TextBox   Grid.Row="1" Grid.Column="1"
                           Name="TxtName" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Giá:" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="1"
                           Name="TxtPrice"/>
            </Grid>
        </StackPanel>

        <!-- ===== RIGHT PANEL ===== -->
        <StackPanel Grid.Column="1" Spacing="10">
            <Button Name="BtnShowList"
                    Content="Hiển thị danh sách sản phẩm"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="8,5"/>

            <DataGrid Name="ProductGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="All"
                      Height="300">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã"  Binding="{Binding Id}"    Width="50"/>
                    <DataGridTextColumn Header="Tên" Binding="{Binding Name}"  Width="*"/>
                    <DataGridTextColumn Header="Giá" Binding="{Binding Price}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

    </Grid>
</Window>
