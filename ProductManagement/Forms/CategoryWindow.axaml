<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="620" d:DesignHeight="420"
        x:Class="ProductManagement.Forms.CategoryWindow"
        x:CompileBindings="False"
        Title="Quản lý danh mục"
        Width="620" Height="420"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12" ColumnDefinitions="220,*">

        <!-- ===== LEFT: Edit Form ===== -->
        <Border Grid.Column="0" Margin="0,0,12,0"
                BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6" Padding="14">
            <StackPanel Spacing="10">

                <TextBlock Text="Chi tiết danh mục" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>

                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="55,*">

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Mã:"
                               VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox   Grid.Row="0" Grid.Column="1" Name="TxtId"
                               IsReadOnly="True" Foreground="Gray" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tên:"
                               VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="1" Grid.Column="1" Name="TxtName"/>
                </Grid>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Center"
                            Spacing="6" Margin="0,10,0,0">
                    <Button Name="BtnAdd"    Content="Thêm"      Padding="12,6"
                            Background="#28A745" Foreground="White"/>
                    <Button Name="BtnUpdate" Content="Sửa"       Padding="12,6"
                            Background="#0D6EFD" Foreground="White"/>
                    <Button Name="BtnDelete" Content="Xóa"       Padding="12,6"
                            Background="#DC3545" Foreground="White"/>
                    <Button Name="BtnClear"  Content="Xóa trắng" Padding="12,6"/>
                </StackPanel>

                <TextBlock Name="TxtStatus" TextWrapping="Wrap"
                           Foreground="#DC3545" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- ===== RIGHT: DataGrid ===== -->
        <DataGrid Grid.Column="1"
                  Name="CategoryGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="All">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã"  Binding="{Binding Id}"   Width="60"/>
                <DataGridTextColumn Header="Tên" Binding="{Binding Name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>
