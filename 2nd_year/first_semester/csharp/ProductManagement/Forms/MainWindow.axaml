<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="950" d:DesignHeight="560"
        x:Class="ProductManagement.Forms.MainWindow"
        x:CompileBindings="False"
        Title="Quản lý sản phẩm"
        Width="950" Height="560"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12" ColumnDefinitions="280,*">

        <!-- ===== LEFT: Detail / Edit Form ===== -->
        <Border Grid.Column="0" Margin="0,0,12,0"
                BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6" Padding="14">
            <StackPanel Spacing="10">

                <TextBlock Text="Chi tiết sản phẩm" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>

                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnDefinitions="80,*">

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Mã:"
                               VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox   Grid.Row="0" Grid.Column="1" Name="TxtId"
                               IsReadOnly="True" Foreground="Gray" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tên:"
                               VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox   Grid.Row="1" Grid.Column="1" Name="TxtName" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Giá:"
                               VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox   Grid.Row="2" Grid.Column="1" Name="TxtPrice" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Danh mục:"
                               VerticalAlignment="Center"/>
                    <ComboBox  Grid.Row="3" Grid.Column="1" Name="CmbCategory"
                               HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Center"
                            Spacing="6" Margin="0,8,0,0">
                    <Button Name="BtnAdd"    Content="Thêm"      Padding="14,6"
                            Background="#28A745" Foreground="White"/>
                    <Button Name="BtnUpdate" Content="Sửa"       Padding="14,6"
                            Background="#0D6EFD" Foreground="White"/>
                    <Button Name="BtnDelete" Content="Xóa"       Padding="14,6"
                            Background="#DC3545" Foreground="White"/>
                    <Button Name="BtnClear"  Content="Xóa trắng" Padding="14,6"/>
                </StackPanel>

                <TextBlock Name="TxtStatus" TextWrapping="Wrap"
                           Foreground="#DC3545" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ===== RIGHT: Filter + DataGrid ===== -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*">

            <!-- Toolbar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
                <TextBlock Text="Danh mục:" VerticalAlignment="Center"/>
                <ComboBox Name="CmbFilterCategory" Width="160">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBox Name="TxtSearch" Width="180" Watermark="Tìm tên sản phẩm..."/>
                <Button Name="BtnSearch"  Content="Tìm"     Padding="10,5"/>
                <Button Name="BtnRefresh" Content="Làm mới" Padding="10,5"/>
                <Button Name="BtnCategories" Content="Quản lý danh mục"
                        Padding="10,5" Background="#6C757D" Foreground="White"/>
            </StackPanel>

            <!-- DataGrid -->
            <DataGrid Grid.Row="1"
                      Name="ProductGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="All">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã"       Binding="{Binding Id}"                    Width="55"/>
                    <DataGridTextColumn Header="Tên"      Binding="{Binding Name}"                  Width="*"/>
                    <DataGridTextColumn Header="Giá"      Binding="{Binding Price, StringFormat=\{0:N0\}}" Width="90"/>
                    <DataGridTextColumn Header="Danh mục" Binding="{Binding CategoryName}"           Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

    </Grid>
</Window>
